# ── Shared ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Backend auth ─────────────────────────────────────────────────────────────
# JWT_SECRET must be at least 16 characters. Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_to_a_long_random_string_minimum_32_chars

# Staff passwords — each must be at least 8 characters. NO default fallbacks.
ERP_ADMIN_PASSWORD=
ERP_SUPPORT_PASSWORD=
ERP_OPS_PASSWORD=
ERP_SALES_PASSWORD=

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/carswise_erp

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5174

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Not needed if using Vite proxy (recommended in dev)
# VITE_API_URL=http://localhost:4000/api

# ── Staff email format (for reference) ───────────────────────────────────────
# admin@carswise.es      → ERP_ADMIN_PASSWORD
# support@carswise.es   → ERP_SUPPORT_PASSWORD
# ops@carswise.es       → ERP_OPS_PASSWORD
# sales@carswise.es     → ERP_SALES_PASSWORD
